# Copy this file to .env and fill in your real keys.
# NEVER commit the actual .env file — it's already excluded in .gitignore.

# NVIDIA NIM API key — get a free one at https://build.nvidia.com
# (open any model page, e.g. meta/llama-3.1-8b-instruct, click "Get API Key")
NVIDIA_API_KEY=nvapi-your-key-here

# SerpAPI key — get one at https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key-here

# Optional: override the ChromaDB persistence path.
# Defaults to /app/hotel_vector_db_langchain if not set (matches the path
# used inside the Hugging Face Space's Docker container).
# VECTOR_DB_PATH=./hotel_vector_db_langchain
